---
interface Project {
  title: string;
  description: string;
  tags: string[];
  image: string;
  demoUrl: string;
  repoUrl: string;
}

const projects: Project[] = [
  {
    title: "Sistema de Gestión de Cabañas",
    description:
      "Sistema completo de gestión de arriendos de cabañas con calendario visual, reservas, integración Firebase (Firestore + Storage), subida de archivos e imágenes, y cálculo automático de montos.",
    tags: ["Next.js", "TypeScript", "Firebase", "Tailwind"],
    image: "/img/sass-arriendos.png",
    demoUrl: "https://next-cabanas-v2.vercel.app/",
    repoUrl: "https://github.com/edurikelm/next-cabanas-v2",
  },
  {
    title: "RACAM Web",
    description:
      "Sitio web corporativo con diseño moderno, galería con modal, formulario de contacto con Web3Forms API y desplegado en Vercel.",
    tags: ["Astro", "CSS", "SCSS", "JavaScript"],
    image: "/img/racam-web.png",
    demoUrl: "https://racam-web-astro.vercel.app/",
    repoUrl: "https://github.com/edurikelm/racam-web-astro",
  },
  {
    title: "Enesfere App",
    description:
      "Ayuda con aplicación empresarial con tabla de datos interactiva para gestión de órdenes de trabajo, construida con Next.js y desplegada en Vercel.",
    tags: ["Next.js", "JavaScript", "Tailwind"],
    image: "/img/enesfere-app.png",
    demoUrl: "https://enesfere-app-next.vercel.app/",
    repoUrl: "https://github.com/edurikelm/enesfere-app-next",
  },
  {
    title: "Dev Books",
    description:
      "Aplicación de libros para desarrolladores con frontend en Astro y backend propio. Tipado con TypeScript y desplegada en Vercel.",
    tags: ["Astro", "TypeScript", "Node.js"],
    image: "📚",
    demoUrl: "https://dev-books-astro-lime.vercel.app/",
    repoUrl: "https://github.com/edurikelm/dev-books-astro",
  },
  {
    title: "Todo App",
    description:
      "Aplicación de gestión de tareas con interfaz moderna, construida con React, Vite y estilizada con Tailwind CSS.",
    tags: ["React", "Vite", "Tailwind", "JavaScript"],
    image: "✅",
    demoUrl: "#",
    repoUrl: "https://github.com/edurikelm/vite-react-tailwind-todo-frontend",
  },
  {
    title: "App Colas",
    description:
      "Aplicación de sistema de colas en tiempo real utilizando WebSockets y Node.js para gestionar turnos de atención.",
    tags: ["Node.js", "Socket.io", "JavaScript"],
    image: "🔄",
    demoUrl: "#",
    repoUrl: "https://github.com/edurikelm/app-colas",
  },
];
---

<section id="proyectos" class="px-6 py-24">
  <div class="mx-auto max-w-6xl">
    <h2 class="mb-16 text-center text-3xl font-bold text-white md:text-4xl">
      Mis <span class="text-cyan-400">Proyectos</span>
    </h2>
    <div class="grid gap-8 md:grid-cols-2">
      {projects.map((project) => (
        <article class="group overflow-hidden rounded-2xl border border-gray-800 bg-gray-900 transition-all hover:border-cyan-500/50">
          <div class="flex h-48 items-center justify-center bg-gray-800 text-6xl transition-transform group-hover:scale-105">
            <img src={project.image} alt={project.title} class="h-full w-full object-cover" />
          </div>
          <div class="p-6">
            <h3 class="mb-3 text-xl font-bold text-white">{project.title}</h3>
            <p class="mb-4 text-sm leading-relaxed text-gray-400">
              {project.description}
            </p>
            <div class="mb-5 flex flex-wrap gap-2">
              {project.tags.map((tag) => (
                <span class="rounded-full bg-cyan-500/10 px-3 py-1 text-xs font-medium text-cyan-400">
                  {tag}
                </span>
              ))}
            </div>
            <div class="flex gap-4">
              <a
                href={project.demoUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="rounded-lg bg-cyan-500 px-5 py-2 text-sm font-semibold text-gray-950 transition-colors hover:bg-cyan-400"
              >
                Demo
              </a>
              <a
                href={project.repoUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="rounded-lg border border-gray-700 px-5 py-2 text-sm font-semibold text-gray-300 transition-colors hover:border-cyan-500 hover:text-cyan-400"
              >
                Código
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
