<section id="inicio" class="relative flex min-h-screen items-center justify-center overflow-hidden px-6 pt-20">
  <div class="absolute inset-0 bg-linear-to-br from-cyan-500/10 via-transparent to-purple-500/10"></div>
  <div class="relative z-10 mx-auto max-w-4xl text-center">
    <p class="mb-4 text-sm font-medium tracking-widest text-cyan-400 uppercase">
      Hola, mi nombre es
    </p>
    <h1 class="mb-6 text-5xl font-extrabold leading-tight text-white md:text-7xl">
      Eduardo Riquelme
    </h1>
    <h2 class="mb-8 text-2xl font-semibold text-gray-400 md:text-3xl">
      Desarrollador Web Full Stack
    </h2>
