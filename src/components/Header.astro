---
const navLinks = [
  { href: "#inicio", label: "Inicio" },
  { href: "#sobre-mi", label: "Sobre mí" },
  { href: "#habilidades", label: "Habilidades" },
  { href: "#proyectos", label: "Proyectos" },
  { href: "#contacto", label: "Contacto" },
];
---

<header class="fixed top-0 z-50 w-full border-b border-gray-800 bg-gray-950/80 backdrop-blur-md">
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
    <a href="#inicio">
      <img src="/img/logo-sin.png" alt="Logo" class="h-12 w-auto" />
    </a>
    <button
      id="menu-toggle"
      class="text-gray-300 hover:text-white md:hidden"
      aria-label="Abrir menú"
    >
      <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
    <ul class="hidden items-center gap-8 md:flex">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="text-sm text-gray-300 transition-colors hover:text-cyan-400"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
  <div id="mobile-menu" class="hidden border-t border-gray-800 md:hidden">
    <ul class="flex flex-col gap-4 px-6 py-4">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="text-sm text-gray-300 transition-colors hover:text-cyan-400"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");
  toggle?.addEventListener("click", () => {
    menu?.classList.toggle("hidden");
  });
  menu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      menu?.classList.add("hidden");
    });
  });
</script>
